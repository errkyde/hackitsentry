# HackIT Sentry – Environment Variables
# Copy this file to .env and fill in real values before deploying.
# Run: cp .env.example .env && ./setup.sh   (setup.sh generates random secrets)

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production

# ── JWT signing key (minimum 32 characters) ───────────────────────────────────
JWT_KEY=change-this-secret-in-production-must-be-at-least-32-chars!!

# ── AES-256 encryption key for stored license/product keys (32 characters) ───
ENCRYPTION_KEY=change-this-aes-key-in-production-32chars!!

# ── Agent check-in interval (minutes) ────────────────────────────────────────
CHECKIN_INTERVAL_MINUTES=30
